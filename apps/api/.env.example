# --- 서버 ---
PORT=3000
NODE_ENV=development
WEB_ORIGIN=http://localhost:5173

# --- DB (SQLite) ---
# 운영(컨테이너) 기본 경로: file:/var/sam-scheduler/data/app.db
DATABASE_URL="file:./data/app.db"

# --- 세션 ---
# 32바이트 이상 무작위 문자열로 변경 필수 (예: openssl rand -hex 32)
SESSION_SECRET=change-me-please-32-bytes-or-more

# --- 초기 ADMIN (첫 기동 시 1회 시딩, 첫 로그인 시 패스워드 변경 강제) ---
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMe!Now

# --- 백업 (DESIGN §7.1) — 자동 실행은 NestJS 스케줄러가 in-process 로 수행 ---
# BACKUP_DB_PATH 와 BACKUP_DIR 비워두면 dev 기본값 (cwd 기준 prisma/data/app.db, data/backup) 사용.
# 운영 컨테이너에서는 절대경로 권장 (예: /var/sam-scheduler/data/app.db, /var/sam-scheduler/backup/daily).
BACKUP_DB_PATH=
BACKUP_DIR=
BACKUP_CRON="0 4 * * *"
BACKUP_RETENTION_DAYS=30
