# --- 외부 노출 포트 ---
HTTP_PORT=8080

# --- 서버 ---
NODE_ENV=production
WEB_ORIGIN=http://localhost:8080

# --- DB (SQLite, 컨테이너 내부 경로) ---
DATABASE_URL=file:/var/seedcore-scheduler/data/app.db

# --- 세션 ---
# 32바이트 이상 무작위 문자열로 변경 필수 (예: openssl rand -hex 32)
SESSION_SECRET=change-me-please-32-bytes-or-more

# --- 초기 ADMIN ---
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=ChangeMe!Now

# --- 백업 (DESIGN §7.1) — 자동 실행은 NestJS 스케줄러가 in-process 로 수행 (Asia/Seoul TZ 고정) ---
# 기존 deploy/scripts/full-backup.sh 등 쉘 스크립트는 수동 백업/복원 fallback 으로만 사용.
BACKUP_DB_PATH=/var/seedcore-scheduler/data/app.db
BACKUP_DIR=/var/seedcore-scheduler/backup/daily
BACKUP_CRON="0 4 * * *"
BACKUP_RETENTION_DAYS=30
