apps/web/vite.config.d.ts
apps/web/tailwind.config.js
apps/web/tailwind.config.d.ts

# tsc -w 가 incremental 캐시 꼬임으로 src/ 에 emit 하는 케이스
packages/shared/src/*.js
packages/shared/src/*.js.map

